{
    "productName": "ElectronScript",
    "version": "0.1.0",
    "identifier": "com.electronscript.app",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:1420",
        "beforeDevCommand": "npm run dev-ui",
        "beforeBuildCommand": "npm run build-ui"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "Electron Script Injector",
                "width": 700,
                "height": 560,
                "resizable": true,
                "center": true
            }
        ],
        "security": {
            "csp": null
        }
    }
}